#!/bin/bash
set -e

action="${1:-show}"
export YNH_APP_ACTION="$action"

set -u

# shellcheck disable=SC1090
source "$(dirname "$0")/_common.sh"

get__add_version() {
  echo ""
}

set__add_version() {
  return 0
}

get__remove_version() {
  echo ""
}

set__remove_version() {
  return 0
}

get__default_version() {
  echo ""
}

set__default_version() {
  return 0
}

get__installed_versions() {
  local output list_items raw_html html
  output="$(sudo -u "$app" -H "$juliaup_bin" status 2>/dev/null || true)"

  raw_html="$(printf '%s' "$output" | sed -e 's/&/&amp;/g' -e 's/</&lt;/g' -e 's/>/&gt;/g' -e 's/\r//g' -e ':a;N;$!ba;s/\n/&#10;/g')"

  list_items="$(echo "$output" | awk '
    /^[[:space:]]*Default[[:space:]]/ { next }
    /^[[:space:]]*-+[[:space:]]*$/ { next }
    /^[[:space:]]*$/ { next }
    {
      line = $0
      sub(/^[[:space:]]*\*[[:space:]]+/, "default ", line)
      sub(/^[[:space:]]+/, "", line)
      gsub(/&/, "&amp;", line)
      gsub(/</, "&lt;", line)
      gsub(/>/, "&gt;", line)
      printf "<li>%s</li>", line
    }
  ')"

  if [ -z "$list_items" ]; then
    list_items="<li>(no versions installed)</li>"
  fi

  html="<details><summary>Raw output</summary><pre>${raw_html}</pre></details><details><summary>Parsed list</summary><ul>${list_items}</ul></details>"
  echo "$html"
}

get__status() {
  echo ""
}

get__add() {
  echo ""
}

get__remove() {
  echo ""
}

get__default() {
  echo ""
}

get__update_versions() {
  echo ""
}

get__update_juliaup() {
  echo ""
}

run__status() {
  sudo -u "$app" -H "$juliaup_bin" status
}

run__add() {
  if [ -z "${add_version:-}" ]; then
    ynh_die --message="Please provide a Julia version or channel to install."
  fi
  sudo -u "$app" -H "$juliaup_bin" add "$add_version"
}

run__remove() {
  if [ -z "${remove_version:-}" ]; then
    ynh_die --message="Please provide a Julia version or channel to remove."
  fi
  sudo -u "$app" -H "$juliaup_bin" remove "$remove_version"
}

run__default() {
  if [ -z "${default_version:-}" ]; then
    ynh_die --message="Please provide a Julia version or channel to set as default."
  fi
  sudo -u "$app" -H "$juliaup_bin" default "$default_version"
}

run__update_versions() {
  sudo -u "$app" -H "$juliaup_bin" update
}

run__update_juliaup() {
  sudo -u "$app" -H "$juliaup_bin" self update
}

ynh_app_config_run "$action"
