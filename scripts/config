#!/bin/bash
set -e

action="${1:-show}"
export YNH_APP_ACTION="$action"

set -u

# shellcheck disable=SC1090
source "$(dirname "$0")/_common.sh"

get__add_version() {
  echo ""
}

set__add_version() {
  return 0
}

get__remove_version() {
  echo ""
}

set__remove_version() {
  return 0
}

get__default_version() {
  echo ""
}

set__default_version() {
  return 0
}

get__installed_versions() {
  _juliaup_status_list
}

get__status() {
  echo ""
}

get__add() {
  echo ""
}

get__remove() {
  echo ""
}

get__default() {
  echo ""
}

get__update_versions() {
  echo ""
}

get__update_juliaup() {
  echo ""
}

get__update_environment() {
  echo ""
}

run__status() {
  _juliaup_exec status
}

run__add() {
  if [ -z "${add_version:-}" ]; then
    ynh_die --message="Please provide a Julia version or channel to install."
  fi
  _run_with_permissions_repair _juliaup_exec add "$add_version"
}

run__remove() {
  if [ -z "${remove_version:-}" ]; then
    ynh_die --message="Please provide a Julia version or channel to remove."
  fi
  _run_with_permissions_repair _juliaup_exec remove "$remove_version"
}

run__default() {
  if [ -z "${default_version:-}" ]; then
    ynh_die --message="Please provide a Julia version or channel to set as default."
  fi
  _run_with_permissions_repair _juliaup_exec default "$default_version"
}

run__update_versions() {
  _run_with_permissions_repair _juliaup_exec update
}

run__update_juliaup() {
  _run_with_permissions_repair _juliaup_exec self update
}

run__update_environment() {
  _run_with_permissions_repair _julia_environment_update
}

ynh_app_config_run "$action"
