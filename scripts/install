#!/bin/bash
set -eu

# shellcheck disable=SC1090
source "$(dirname "$0")/_common.sh"

# Ensure home exists for juliaup
mkdir -p "/home/$app"
mkdir -p "$juliaup_depot"
chown -R "$app:$app" "/home/$app"

# If a stale juliaup config exists without a juliaup binary, clean it up
if [ ! -x "$juliaup_bin" ] && [ -f "$juliaup_depot/juliaup/juliaup.json" ]; then
  rm -f "$juliaup_depot/juliaup/juliaup.json"
fi

sudo -u "$app" -H env JULIAUP_DEPOT_PATH="$juliaup_depot" bash << 'EOF'
curl -fsSL https://install.julialang.org | sh -s -- -y --add-to-path=no --background-selfupdate=0
EOF

# Allow system-wide execution of Julia binaries (read/exec only for others)
chmod 755 "/home/$app"
chmod -R o+rx "/home/$app/.juliaup"
chmod -R o+rx "/home/$app/.julia"

# Allow all users to create juliaup lockfiles (needed by the julia launcher)
mkdir -p "$juliaup_depot/juliaup"
chown -R "$app:$app" "$juliaup_depot"
chmod 1777 "$juliaup_depot/juliaup"

cat > "/etc/profile.d/$app.sh" << EOF
if [ "${USER:-}" = "$app" ]; then
  export PATH="/home/$app/.juliaup/bin:$PATH"
fi
EOF

# Global launcher for the primary instance
if [ "$app" = "julia" ]; then
  cat > "/usr/local/bin/julia" << EOF
#!/bin/bash
set -eu
export JULIAUP_DEPOT_PATH="/home/$app/.julia"
export JULIAUP_CHANNEL="${JULIAUP_CHANNEL:-release}"
exec "/home/$app/.juliaup/bin/julia" "$@"
EOF
  chmod 755 "/usr/local/bin/julia"
fi

sudo -u "$app" -H "$juliaup_bin" status
