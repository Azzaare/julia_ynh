#!/bin/bash
set -eu

# shellcheck disable=SC1090
source "$(dirname "$0")/_common.sh"

# Ensure home exists for juliaup
mkdir -p "$install_dir"
mkdir -p "$juliaup_depot"
chown -R "$app:$app" "$install_dir"
ynh_app_setting_set --app="$app" --key=install_dir --value="$install_dir"

# If a stale juliaup config exists without a juliaup binary, clean it up
if [ ! -x "$juliaup_bin" ] && [ -f "$juliaup_depot/juliaup/juliaup.json" ]; then
  rm -f "$juliaup_depot/juliaup/juliaup.json"
fi

ynh_exec_as_app env JULIAUP_DEPOT_PATH="$juliaup_depot" bash -c \
  'curl -fsSL https://install.julialang.org | sh -s -- -y --add-to-path=no --background-selfupdate=0'

ensure_juliaup_permissions

cat > "/etc/profile.d/$app.sh" << EOF
if [ "${USER:-}" = "$app" ]; then
  export PATH="$install_dir/.juliaup/bin:$PATH"
fi
EOF

ynh_exec_as_app "$juliaup_bin" status
