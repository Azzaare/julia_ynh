#!/bin/bash
set -eu

# shellcheck disable=SC1090
source "$(dirname "$0")/_common.sh"

if [ -d "/home/$app" ] && [ ! -d "$install_dir" ]; then
  ynh_print_info "Migrating data directory from /home/$app to $install_dir"
  mv "/home/$app" "$install_dir"
  chown -R "$app:$app" "$install_dir"
fi

ynh_app_setting_set --app="$app" --key=install_dir --value="$install_dir"

ynh_exec_as_app "$juliaup_bin" self update
ynh_exec_as_app "$juliaup_bin" update

ensure_juliaup_permissions
